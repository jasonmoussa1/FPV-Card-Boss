{
  "name": "fpv-card-boss",
  "private": true,
  "version": "1.2.0",
  "type": "module",
  "main": "main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "dev:electron": "concurrently -k \"vite\" \"wait-on http://localhost:3000 && electron .\"",
    "build:server": "esbuild dashboardServer.cjs --bundle --platform=node --format=cjs --outfile=dashboardServer.bundled.cjs --external:bufferutil --external:utf-8-validate",
    "build:slate": "vite build --config vite.slate.config.ts",
    "build:exe": "tsc --noEmit && vite build && npm run build:slate && npm run build:server && electron-builder --win && node deploy.cjs",
    "build:mac": "tsc --noEmit && vite build && npm run build:slate && npm run build:server && electron-builder --mac"
  },
  "build": {
    "appId": "com.fpvcardboss.app",
    "productName": "FPV Card Boss",
    "directories": {
      "output": "C:/Temp/fpv-card-boss-release"
    },
    "win": {
      "target": [
        "portable"
      ],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": [
        "dir"
      ],
      "category": "public.app-category.video",
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "NSAppleEventsUsageDescription": "FPV Card Boss controls GoPro Player and Finder to automate the stabilization export.",
        "NSAccessibilityUsageDescription": "FPV Card Boss moves the mouse and keyboard to drive GoPro Player's export."
      }
    },
    "asarUnpack": [
      "**/node_modules/@nut-tree-fork/**",
      "**/node_modules/@nut-tree/**"
    ],
    "files": [
      "dist/**/*",
      "dist-slate/**/*",
      "main.cjs",
      "preload.cjs",
      "platform.cjs",
      "mac-robot.cjs",
      "mac-fs.cjs",
      "calibration.html",
      "dashboardServer.cjs",
      "dashboardServer.bundled.cjs",
      "assets/icon-192.png",
      "assets/icon-512.png"
    ]
  },
  "dependencies": {
    "@emotion/is-prop-valid": "^1.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "express": "^5.2.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "qrcode": "^1.5.4",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3",
    "ws": "^8.21.0"
  },
  "optionalDependencies": {
    "@nut-tree-fork/nut-js": "^4.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite-plugin-singlefile": "^2.3.3",
    "wait-on": "^9.0.10"
  }
}
